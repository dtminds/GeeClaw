#!/bin/sh
# OpenCLI CLI wrapper for Git Bash / MSYS2 on Windows
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
INSTALL_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"

case "$1" in
  update)
    echo "opencli is managed by GeeClaw (bundled version)."
    echo ""
    echo "To update opencli, update GeeClaw:"
    echo "  Open GeeClaw > Settings > Check for Updates"
    exit 0
    ;;
esac

export OPENCLI_EMBEDDED_IN="GeeClaw"
NODE_EXE="$INSTALL_DIR/resources/bin/node.exe"
OPENCLI_ENTRY="$INSTALL_DIR/resources/opencli/dist/main.js"

if [ -f "$NODE_EXE" ]; then
  if "$NODE_EXE" -e 'const [maj,min]=process.versions.node.split(".").map(Number);process.exit((maj>22||maj===22&&min>=16)?0:1)' >/dev/null 2>&1; then
    exec "$NODE_EXE" "$OPENCLI_ENTRY" "$@"
  fi
fi

ELECTRON_RUN_AS_NODE=1 exec "$INSTALL_DIR/GeeClaw.exe" "$OPENCLI_ENTRY" "$@"
