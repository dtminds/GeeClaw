#!/bin/sh
# OpenClaw CLI wrapper for Git Bash / MSYS2 on Windows
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
INSTALL_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"

case "$1" in
  update)
    echo "openclaw is managed by GeeClaw (bundled version)."
    echo ""
    echo "To update openclaw, update GeeClaw:"
    echo "  Open GeeClaw > Settings > Check for Updates"
    exit 0
    ;;
esac

export OPENCLAW_EMBEDDED_IN="GeeClaw"
export OPENCLAW_STATE_DIR="${USERPROFILE:-$HOME}/.openclaw-geeclaw"
export OPENCLAW_CONFIG_PATH="${OPENCLAW_STATE_DIR}/openclaw.json"
NODE_EXE="$INSTALL_DIR/resources/bin/node.exe"
LEGACY_ENTRY="$INSTALL_DIR/resources/openclaw/openclaw.mjs"
if [ -n "${GEECLAW_USER_DATA_DIR:-}" ]; then
  USER_DATA_DIR="$GEECLAW_USER_DATA_DIR"
elif [ -n "${APPDATA:-}" ]; then
  USER_DATA_DIR="$APPDATA/GeeClaw"
else
  USER_DATA_DIR="${USERPROFILE:-$HOME}/AppData/Roaming/GeeClaw"
fi
SIDECAR_ENTRY="$USER_DATA_DIR/runtime/openclaw-sidecar/openclaw.mjs"
if [ -f "$SIDECAR_ENTRY" ]; then
  OPENCLAW_ENTRY="$SIDECAR_ENTRY"
else
  OPENCLAW_ENTRY="$LEGACY_ENTRY"
fi
PROFILE_NAME="geeclaw"
PROFILE_ARG=""
PREV_WAS_PROFILE=0

for arg in "$@"; do
  if [ "$PREV_WAS_PROFILE" -eq 1 ]; then
    PROFILE_ARG="$arg"
    PREV_WAS_PROFILE=0
    continue
  fi

  case "$arg" in
    --profile)
      PREV_WAS_PROFILE=1
      ;;
    --profile=*)
      PROFILE_ARG="${arg#--profile=}"
      ;;
  esac
done

if [ -n "$PROFILE_ARG" ] && [ "$PROFILE_ARG" != "$PROFILE_NAME" ]; then
  echo "Error: GeeClaw wrapper only supports --profile $PROFILE_NAME (got: $PROFILE_ARG)" >&2
  exit 1
fi

if [ ! -f "$OPENCLAW_ENTRY" ]; then
  echo "Error: bundled openclaw entry not found at $OPENCLAW_ENTRY" >&2
  echo "Please reinstall GeeClaw or remove this script: $0" >&2
  exit 1
fi

if [ ! -f "$NODE_EXE" ]; then
  echo "Error: bundled Node.js runtime not found at $NODE_EXE" >&2
  echo "Please reinstall GeeClaw or remove this script: $0" >&2
  exit 1
fi

if "$NODE_EXE" -e 'const [maj,min]=process.versions.node.split(".").map(Number);process.exit((maj>22||maj===22&&min>=16)?0:1)' >/dev/null 2>&1; then
  if [ -n "$PROFILE_ARG" ]; then
    exec "$NODE_EXE" "$OPENCLAW_ENTRY" "$@"
  fi
  exec "$NODE_EXE" "$OPENCLAW_ENTRY" --profile "$PROFILE_NAME" "$@"
fi

echo "Error: bundled Node.js runtime at $NODE_EXE is too old or failed to start" >&2
echo "Please reinstall GeeClaw." >&2
exit 1
