#!/bin/sh
# OpenClaw CLI — managed by GeeClaw
# Do not edit manually. Regenerated on GeeClaw updates.

# Resolve the real path of this script (follow symlinks)
SCRIPT="$0"
while [ -L "$SCRIPT" ]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"
  SCRIPT="$(readlink "$SCRIPT")"
  [ "${SCRIPT#/}" = "$SCRIPT" ] && SCRIPT="$SCRIPT_DIR/$SCRIPT"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"

PROJECT_ROOT="$(cd -P "$SCRIPT_DIR/../../.." 2>/dev/null && pwd)"
NODE_SHIM="$SCRIPT_DIR/node"

bin_arch() {
  case "$(uname -m)" in
    x86_64|amd64) echo "x64" ;;
    arm64|aarch64) echo "arm64" ;;
    *) uname -m ;;
  esac
}

PATH_PREFIX="$SCRIPT_DIR"
STATE_DIR="${HOME}/.openclaw-geeclaw"
CONFIG_PATH="${STATE_DIR}/openclaw.json"
PROFILE_NAME="geeclaw"

if [ -f "$PROJECT_ROOT/openclaw-runtime/node_modules/openclaw/openclaw.mjs" ]; then
  CLI="$PROJECT_ROOT/openclaw-runtime/node_modules/openclaw/openclaw.mjs"
  DEV_BUNDLED_ROOT="$PROJECT_ROOT/resources/bin/$(uname | tr '[:upper:]' '[:lower:]')-$(bin_arch)"
  DEV_BUNDLED_BIN="$PROJECT_ROOT/resources/bin/$(uname | tr '[:upper:]' '[:lower:]')-$(bin_arch)/bin"
  if [ -d "$DEV_BUNDLED_ROOT" ]; then
    PATH_PREFIX="$PATH_PREFIX:$DEV_BUNDLED_ROOT"
  fi
  if [ -d "$DEV_BUNDLED_BIN" ]; then
    PATH_PREFIX="$PATH_PREFIX:$DEV_BUNDLED_BIN"
  fi
elif [ -f "$PROJECT_ROOT/node_modules/openclaw/openclaw.mjs" ]; then
  CLI="$PROJECT_ROOT/node_modules/openclaw/openclaw.mjs"
  DEV_BUNDLED_ROOT="$PROJECT_ROOT/resources/bin/$(uname | tr '[:upper:]' '[:lower:]')-$(bin_arch)"
  DEV_BUNDLED_BIN="$PROJECT_ROOT/resources/bin/$(uname | tr '[:upper:]' '[:lower:]')-$(bin_arch)/bin"
  if [ -d "$DEV_BUNDLED_ROOT" ]; then
    PATH_PREFIX="$PATH_PREFIX:$DEV_BUNDLED_ROOT"
  fi
  if [ -d "$DEV_BUNDLED_BIN" ]; then
    PATH_PREFIX="$PATH_PREFIX:$DEV_BUNDLED_BIN"
  fi
elif [ "$(uname)" = "Darwin" ]; then
  # macOS: <App>.app/Contents/Resources/managed-bin/openclaw
  # SCRIPT_DIR = .../Contents/Resources/managed-bin
  CONTENTS_DIR="$(dirname "$(dirname "$SCRIPT_DIR")")"
  CLI="$CONTENTS_DIR/Resources/openclaw/openclaw.mjs"
  BUNDLED_ROOT="$CONTENTS_DIR/Resources/bin"
  BUNDLED_BIN="$CONTENTS_DIR/Resources/bin/bin"
  if [ -d "$BUNDLED_ROOT" ]; then
    PATH_PREFIX="$PATH_PREFIX:$BUNDLED_ROOT"
  fi
  if [ -d "$BUNDLED_BIN" ]; then
    PATH_PREFIX="$PATH_PREFIX:$BUNDLED_BIN"
  fi
else
  # Linux: /opt/GeeClaw/resources/managed-bin/openclaw
  # SCRIPT_DIR = .../resources/managed-bin
  INSTALL_DIR="$(dirname "$(dirname "$SCRIPT_DIR")")"
  CLI="$INSTALL_DIR/resources/openclaw/openclaw.mjs"
  BUNDLED_ROOT="$INSTALL_DIR/resources/bin"
  BUNDLED_BIN="$INSTALL_DIR/resources/bin/bin"
  if [ -d "$BUNDLED_ROOT" ]; then
    PATH_PREFIX="$PATH_PREFIX:$BUNDLED_ROOT"
  fi
  if [ -d "$BUNDLED_BIN" ]; then
    PATH_PREFIX="$PATH_PREFIX:$BUNDLED_BIN"
  fi
fi

if [ ! -x "$NODE_SHIM" ]; then
  echo "Error: GeeClaw node shim not found at $NODE_SHIM" >&2
  echo "Please reinstall GeeClaw or remove this script: $0" >&2
  exit 1
fi

if [ ! -f "$CLI" ]; then
  echo "Error: bundled openclaw entry not found at $CLI" >&2
  echo "Please reinstall GeeClaw or remove this script: $0" >&2
  exit 1
fi

case "$1" in
  update)
    echo "openclaw is managed by GeeClaw (bundled version)."
    echo ""
    echo "To update openclaw, update GeeClaw:"
    echo "  Open GeeClaw > Settings > Check for Updates"
    echo "  Or download the latest version from https://geeclaw.chat"
    echo ""
    "$NODE_SHIM" "$CLI" --version 2>/dev/null || true
    exit 0
    ;;
esac

PROFILE_ARG=""
PREV_WAS_PROFILE=0
for arg in "$@"; do
  if [ "$PREV_WAS_PROFILE" -eq 1 ]; then
    PROFILE_ARG="$arg"
    PREV_WAS_PROFILE=0
    continue
  fi

  case "$arg" in
    --profile)
      PREV_WAS_PROFILE=1
      ;;
    --profile=*)
      PROFILE_ARG="${arg#--profile=}"
      ;;
  esac
done

if [ -n "$PROFILE_ARG" ] && [ "$PROFILE_ARG" != "$PROFILE_NAME" ]; then
  echo "Error: GeeClaw wrapper only supports --profile $PROFILE_NAME (got: $PROFILE_ARG)" >&2
  exit 1
fi

export OPENCLAW_EMBEDDED_IN="GeeClaw"
export OPENCLAW_STATE_DIR="$STATE_DIR"
export OPENCLAW_CONFIG_PATH="$CONFIG_PATH"
export PATH="$PATH_PREFIX${PATH:+:$PATH}"

if [ -n "$PROFILE_ARG" ]; then
  exec "$NODE_SHIM" "$CLI" "$@"
fi

exec "$NODE_SHIM" "$CLI" --profile "$PROFILE_NAME" "$@"
