#!/bin/sh
# mcporter CLI — managed by GeeClaw
# Do not edit manually. Regenerated on GeeClaw updates.

SCRIPT="$0"
while [ -L "$SCRIPT" ]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"
  SCRIPT="$(readlink "$SCRIPT")"
  [ "${SCRIPT#/}" = "$SCRIPT" ] && SCRIPT="$SCRIPT_DIR/$SCRIPT"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"

PROJECT_ROOT="$(cd -P "$SCRIPT_DIR/../../.." 2>/dev/null && pwd)"

bin_arch() {
  case "$(uname -m)" in
    x86_64|amd64) echo "x64" ;;
    arm64|aarch64) echo "arm64" ;;
    *) uname -m ;;
  esac
}

PATH_PREFIX="$SCRIPT_DIR"

if [ -f "$PROJECT_ROOT/build/mcporter/dist/cli.js" ]; then
  CLI="$PROJECT_ROOT/build/mcporter/dist/cli.js"
  if [ "$(uname)" = "Darwin" ]; then
    ELECTRON="$PROJECT_ROOT/node_modules/electron/dist/Electron.app/Contents/MacOS/Electron"
  else
    ELECTRON="$PROJECT_ROOT/node_modules/electron/dist/electron"
  fi
  DEV_BUNDLED_BIN="$PROJECT_ROOT/resources/bin/$(uname | tr '[:upper:]' '[:lower:]')-$(bin_arch)"
  if [ -d "$DEV_BUNDLED_BIN" ]; then
    PATH_PREFIX="$PATH_PREFIX:$DEV_BUNDLED_BIN"
  fi
elif [ "$(uname)" = "Darwin" ]; then
  CONTENTS_DIR="$(dirname "$(dirname "$SCRIPT_DIR")")"
  ELECTRON="$CONTENTS_DIR/MacOS/GeeClaw"
  CLI="$CONTENTS_DIR/Resources/mcporter/dist/cli.js"
  BUNDLED_BIN="$CONTENTS_DIR/Resources/bin"
  if [ -d "$BUNDLED_BIN" ]; then
    PATH_PREFIX="$PATH_PREFIX:$BUNDLED_BIN"
  fi
else
  INSTALL_DIR="$(dirname "$(dirname "$SCRIPT_DIR")")"
  ELECTRON="$INSTALL_DIR/geeclaw"
  CLI="$INSTALL_DIR/resources/mcporter/dist/cli.js"
  BUNDLED_BIN="$INSTALL_DIR/resources/bin"
  if [ -d "$BUNDLED_BIN" ]; then
    PATH_PREFIX="$PATH_PREFIX:$BUNDLED_BIN"
  fi
fi

if [ ! -f "$ELECTRON" ]; then
  echo "Error: GeeClaw executable not found at $ELECTRON" >&2
  echo "Please reinstall GeeClaw or remove this script: $0" >&2
  exit 1
fi

case "$1" in
  update)
    echo "mcporter is managed by GeeClaw (bundled version)."
    echo ""
    echo "To update mcporter, update GeeClaw:"
    echo "  Open GeeClaw > Settings > Check for Updates"
    echo "  Or download the latest version from https://geeclaw.chat"
    exit 0
    ;;
esac

export PATH="$PATH_PREFIX${PATH:+:$PATH}"
ELECTRON_RUN_AS_NODE=1 exec "$ELECTRON" "$CLI" "$@"
