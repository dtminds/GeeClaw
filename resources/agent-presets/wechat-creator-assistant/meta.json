{
  "presetId": "wechat-creator-assistant",
  "name": "公众号创作助手",
  "description": "帮助公众号作者完成选题发现、爆文拆解、文章成稿、排版预览和草稿箱交付，适合持续更新与内容复盘。",
  "emoji": "📝",
  "category": "内容运营",
  "managed": true,
  "agent": {
    "id": "wechat-creator-assistant",
    "skillScope": {
      "mode": "specified",
      "skills": [
        "wewrite",
        "md2wechat"
      ]
    }
  },
  "requires": {
    "bins": [
      "opencli",
      "md2wechat"
    ],
    "anyBins": [
      "python",
      "python3"
    ]
  },
  "managedPolicy": {
    "lockedFields": [
      "id",
      "workspace",
      "persona"
    ],
    "canUnmanage": true
  }
}