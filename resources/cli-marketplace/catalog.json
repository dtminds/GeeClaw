[
    {
        "id": "mcporter",
        "title": "MCPorter",
        "binNames": [
            "mcporter"
        ],
        "installMethods": [
            {
                "type": "managed-npm",
                "packageName": "mcporter"
            }
        ],
        "description": "通过命令行调用 MCP 服务，必装",
        "homepage": "mcporter.dev",
        "docsUrl": "https://mcporter.dev",
        "platforms": [
            "darwin",
            "win32"
        ]
    },
    {
        "id": "dokobot",
        "title": "Dokobot",
        "binNames": [
            "dokobot"
        ],
        "installMethods": [
            {
                "type": "managed-npm",
                "packageName": "@dokobot/cli",
                "postInstallActions": [
                    {
                        "type": "run-installed-bin",
                        "bin": "dokobot",
                        "args": [
                            "install-skill",
                            "-o",
                            "${openclawSkillsDir}"
                        ]
                    }
                ],
                "completion": {
                    "kind": "skills-and-docs",
                    "requiresSkillEnable": true,
                    "extraSteps": [
                        "安装浏览器扩展",
                        "完成 bridge 配置",
                        "在技能页开启 OpenCLI 技能"
                    ]
                }
            }
        ],
        "description": "提取网页可读内容供 AI 处理，复用所有登录会话，当 Agent 需要读取网页内容而非操控浏览器时使用",
        "homepage": "https://dokobot.ai/zh-CN",
        "docsUrl": "https://dokobot.ai/zh-CN/guide",
        "platforms": [
            "darwin",
            "win32"
        ]
    },
    {
        "id": "opencli",
        "title": "OpenCLI",
        "binNames": [
            "opencli"
        ],
        "installMethods": [
            {
                "type": "managed-npm",
                "packageName": "@jackwener/opencli",
                "postInstallActions": [
                    {
                        "type": "install-skills",
                        "sources": [
                            "jackwener/opencli"
                        ]
                    }
                ],
                "completion": {
                    "kind": "skills-and-docs",
                    "requiresSkillEnable": true,
                    "extraSteps": [
                        "安装浏览器扩展",
                        "在技能页开启 opencli 技能"
                    ]
                }
            }
        ],
        "description": "将任何网站或 Electron 应用转化为强大的命令行工具供 Agent 使用，复用 Chrome 登录状态",
        "homepage": "https://opencli.info/",
        "docsUrl": "https://opencli.info/docs/zh/guide/browser-bridge.html",
        "platforms": [
            "darwin",
            "win32"
        ]
    },
    {
        "id": "dreamina",
        "title": "即梦 CLI",
        "binNames": [
            "dreamina"
        ],
        "installMethods": [
            {
                "type": "manual",
                "label": "curl",
                "command": "curl -s https://jimeng.jianying.com/cli | bash",
                "requiresCommands": [
                    "curl",
                    "bash"
                ]
            }
        ],
        "description": "让你的 AGENT 能够使用即梦生成工具，把批量任务、定时任务交给自动化，把时间还给你自己",
        "homepage": "https://jimeng.jianying.com/cli",
        "docsUrl": "https://bytedance.larkoffice.com/wiki/FVTwwm0bGiishxkKOoScdHR2nsg",
        "platforms": [
            "darwin",
            "win32"
        ]
    },
    {
        "id": "feishu",
